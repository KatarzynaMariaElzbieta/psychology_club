{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "numReplicas": 1
  },
  "services": [
    {
      "name": "web",
      "startCommand": "poetry run gunicorn -w 2 -b 0.0.0.0:8080 wsgi:app"
    },
    {
      "name": "worker",
      "startCommand": "poetry run rq worker mailing --with-scheduler"
    }
  ]
}
